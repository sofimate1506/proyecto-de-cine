ALTER TABLE empleados ENABLE ROW LEVEL SECURITY;

CREATE POLICY "empleado_ver_solo_el_suyo"
ON empleados FOR SELECT
USING (correo = current_user);

CREATE POLICY "empleado_editar_solo_el_suyo"
ON empleados FOR UPDATE
USING (correo = current_user)
WITH CHECK (correo = current_user);

CREATE OR REPLACE FUNCTION bloquear_insert_empleados()
RETURNS TRIGGER AS $$
BEGIN
    RAISE EXCEPTION 'No se pueden registrar nuevos empleados desde este sistema.';
    RETURN NULL;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trigger_bloquear_registro
BEFORE INSERT ON empleados
FOR EACH ROW EXECUTE FUNCTION bloquear_insert_empleados();

SELECT id, nombre, apellido, activo, creado_en
FROM empleados;
